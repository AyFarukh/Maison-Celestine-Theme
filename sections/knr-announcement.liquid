<style>
  .knr-announce {
    background: var(--knr-ink);
    color: var(--knr-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    height: 36px;
    padding: 0 16px;
    font-family: var(--knr-font);
    font-size: var(--knr-text-11);
    letter-spacing: .09em;
    text-transform: uppercase;
    width: 100%;
    max-width: {{ section.settings.section_max_width }}px;
    margin: 0 auto;
  }

  .knr-announce a {
    color: inherit;
    text-underline-offset: 3px;
  }

  .knr-announce a:hover {
    text-decoration: underline;
  }
</style>

{%- if section.settings.enabled and section.settings.text != blank -%}
  <div class="knr-announce">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
    {%- else -%}
      {{ section.settings.text }}
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "KNR Announcement",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Livraison offerte dès 75 € — Retours gratuits 30 jours"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Section max width",
      "min": 960,
      "max": 1680,
      "step": 20,
      "default": 1440
    }
  ],
  "presets": [{ "name": "KNR Announcement" }]
}
{% endschema %}
