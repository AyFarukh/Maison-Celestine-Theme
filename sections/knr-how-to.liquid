<style>
  .knr-how-to {
    padding: 80px 40px;
    background: var(--knr-sand);
    font-family: var(--knr-font);
    width: 100%;
    max-width: {{ section.settings.section_max_width }}px;
    margin: 0 auto;
  }

  .knr-how-to__hd {
    margin-bottom: 40px;
  }

.knr-how-to__title {
    /* font-size: var(--knr-text-28); */
    /* font-weight: 300; */
    /* letter-spacing: .06em; */
    color: var(--knr-ink);
    margin: 0;
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 32px;
    line-height: 40px;
    letter-spacing: -0.04em;
    /* text-align: center; */
    /* vertical-align: middle; */
}

  .knr-how-to__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    {% comment %} max-width: {{ section.settings.section_max_width }}px; {% endcomment %}
    margin: 0 auto;
  }

  .knr-how-to__step {}

  .knr-how-to__img {
    aspect-ratio: 2/2;
    overflow: hidden;
    background: var(--knr-sand-dark);
    margin-bottom: 20px;
  }

  .knr-how-to__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .45s ease;
  }

  .knr-how-to__step:hover .knr-how-to__img img {
    transform: scale(1.03);
  }

.knr-how-to__tag {
    font-size: 14px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--knr-ink-60);
    margin-bottom: 16px;
    font-weight: 400;
}
.knr-how-to__name {
    font-size: 24px;
    font-weight: 400;
    color: var(--knr-ink);
    letter-spacing: .03em;
    margin: 0 0 16px;
}

 .knr-how-to__desc {
    color: #000;
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 14px;
    line-height: 22px;
    letter-spacing: -0.02em;
    vertical-align: middle;
}

  /* Slider footer — hidden on desktop */
  .knr-how-to__slider-footer {
    display: none;
  }

  @media (max-width: 860px) {
    .knr-how-to {
      padding: 40px 0 40px;
     padding-left: 24px;

    }

    /* Title keeps its side padding */
    .knr-how-to__hd {
      
      margin-bottom: 32px;
    }

    /* Viewport: flush to both edges */
    .knr-how-to__viewport {
      overflow-x: auto;
      overflow-y: hidden;
      padding-left: 20px;
      padding-right: 20px;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      scroll-behavior: smooth;
      touch-action: pan-y pinch-zoom;
    }

    .knr-how-to__viewport::-webkit-scrollbar {
      display: none;
    }

    /* Grid → horizontal flex row */
    .knr-how-to__grid {
      display: flex;
      grid-template-columns: unset;
      gap: 12px;
      width: max-content;
    }

    /* Each card = main slide with next card peeking in */
    .knr-how-to__step {
      flex: 0 0 min(calc({{ section.settings.mobile_card_width_percent }}vw), calc(100vw - 64px));
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }

    .knr-how-to__img {
      aspect-ratio: 1 / 1;
      margin-bottom: 18px;
    }

    .knr-how-to__tag {
      font-size: 12px;
      margin-bottom: 14px;
      color: var(--knr-ink);
    }

    .knr-how-to__name {
      font-family: 'Inter', sans-serif;
  font-weight: 400;
  font-style: normal;
  font-size: 24px;
  line-height: 40px;
  letter-spacing: -0.04em; /* -4% */
  
  vertical-align: middle;
    }

    .knr-how-to__desc {
        font-family: 'Inter', sans-serif;
  font-weight: 400;
  font-style: normal;
  font-size: 14px;
  line-height: 40px;
  letter-spacing: -0.04em; /* -4% */
    }

    /* Progress bar */
    .knr-how-to__slider-footer {
      display: flex;
      justify-content: center;
      margin-top: 28px;
      padding: 0 20px;
    }

    .knr-how-to__scrollbar {
      position: relative;
      width: {{ section.settings.mobile_progress_width }}px;
      height: {{ section.settings.mobile_progress_thickness }}px;
      background: #d9cfbc;
      position: relative;
      overflow: hidden;
    }

    .knr-how-to__scrollbar-thumb {
      position: absolute;
      top: 0;
      left: 0;
      width: 33.3333%;
      height: 100%;
      background: #111111;
      transition: left 0.22s ease, width 0.22s ease;
      will-change: left, width;
    }
  }

  @media (max-width: 560px) {
    .knr-how-to__title {
      font-family: 'Inter', sans-serif;
  font-weight: 400;
  font-style: normal;
  font-size: 32px;
  line-height: 40px;
  letter-spacing: -0.04em; /* -4% */
 
  vertical-align: middle;
    }

    .knr-how-to__step {
      flex-basis: min(calc({{ section.settings.mobile_card_width_percent }}vw), calc(100vw - 56px));
    }
  }
</style>

<section class="knr-how-to ">
  <div class="knr-how-to__hd">
    <h2 class="knr-how-to__title">{{ section.settings.title }}</h2>
  </div>

  <div class="knr-how-to__viewport">
    <div class="knr-how-to__grid">
      {%- for block in section.blocks -%}
        <div class="knr-how-to__step" {{ block.shopify_attributes }}>
          <div class="knr-how-to__img">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 700 }}"
                alt="{{ block.settings.name | escape }}"
                width="460" height="614"
                loading="lazy"
              >
            {%- endif -%}
          </div>
          <p class="knr-how-to__tag">{{ block.settings.tag }}</p>
          <h3 class="knr-how-to__name">{{ block.settings.name }}</h3>
          <p class="knr-how-to__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="knr-how-to__slider-footer">
    <div class="knr-how-to__scrollbar" aria-hidden="true">
      <div class="knr-how-to__scrollbar-thumb"></div>
    </div>
  </div>
</section>

<script>
(function () {
  var section  = document.querySelector('#shopify-section-{{ section.id }}');
  if (!section) return;
  var viewport = section.querySelector('.knr-how-to__viewport');
  var thumb    = section.querySelector('.knr-how-to__scrollbar-thumb');
  if (!viewport || !thumb) return;
  var steps    = viewport.querySelectorAll('.knr-how-to__step');
  if (!steps.length) return;

  function updateThumb() {
    var items = steps.length || 1;
    if (items <= 1) {
      thumb.style.width = '100%';
      thumb.style.left = '0%';
      return;
    }

    var lastStep = steps[items - 1];
    var lastOffset = lastStep ? lastStep.offsetLeft : 0;
    var thumbPct = 100 / items;

    if (lastOffset <= 0) {
      thumb.style.width = thumbPct + '%';
      thumb.style.left = '0%';
      return;
    }

    var rawProgress = viewport.scrollLeft / lastOffset;
    var progress = Math.min(1, Math.max(0, rawProgress));
    var leftPct = progress * (100 - thumbPct);

    thumb.style.width = thumbPct + '%';
    thumb.style.left = leftPct + '%';
  }

  viewport.addEventListener('scroll', updateThumb, { passive: true });
  setTimeout(updateThumb, 100);
  window.addEventListener('resize', updateThumb, { passive: true });
})();
</script>

{% schema %}
{
  "name": "KNR How to Use",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "How to use"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Section max width",
      "min": 960,
      "max": 1680,
      "step": 20,
      "default": 1440
    },
    {
      "type": "range",
      "id": "mobile_card_width_percent",
      "label": "Mobile slide width (%)",
      "min": 68,
      "max": 92,
      "step": 2,
      "default": 76
    },
    {
      "type": "range",
      "id": "mobile_progress_width",
      "label": "Mobile progress width",
      "min": 80,
      "max": 200,
      "step": 4,
      "default": 144
    },
    {
      "type": "range",
      "id": "mobile_progress_thickness",
      "label": "Mobile progress thickness",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "tag",   "label": "Tag",   "default": "Découvrir" },
        { "type": "text", "id": "name",  "label": "Name",  "default": "Régénérer & Lisser" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Appliquer les végétaux sur la peau pour une action régénératrice et anti-âge naturelle." }
      ]
    }
  ],
  "presets": [
    {
      "name": "KNR How to Use",
      "blocks": [
        { "type": "step", "settings": { "tag": "Découvrir", "name": "Régénérer & Lisser", "description": "Appliquer les végétaux sur la peau pour une action régénératrice naturelle." } },
        { "type": "step", "settings": { "tag": "Découvrir", "name": "Hydrater",           "description": "Notre formule pénètre en profondeur pour une hydratation longue durée." } },
        { "type": "step", "settings": { "tag": "Découvrir", "name": "Sublimer",            "description": "Révélez l'éclat naturel de votre peau grâce à nos actifs botaniques." } }
      ]
    }
  ]
}
{% endschema %}
