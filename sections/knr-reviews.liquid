<style>
  #shopify-section-{{ section.id }} .knr-reviews {
    --review-bg: {{ section.settings.bg_color }};
    --review-ink: {{ section.settings.text_color }};
    --review-muted: {{ section.settings.muted_color }};
    --review-gold: {{ section.settings.accent_color }};
    background: var(--review-bg);
    color: var(--review-ink);
    font-family: var(--knr-font);
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    width: 100%;
    max-width: {{ section.settings.section_max_width }}px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .knr-reviews__inner {
    max-width: {{ section.settings.section_max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .knr-reviews__title {
    font-size: var(--knr-text-28);
    font-weight: 300;
    letter-spacing: .06em;
    margin: 0 0 38px;
  }

  #shopify-section-{{ section.id }} .knr-reviews__viewport {
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .knr-reviews__track {
    display: flex;
    transition: transform .45s ease;
    will-change: transform;
  }

  #shopify-section-{{ section.id }} .knr-review {
    flex: 0 0 100%;
    padding: 0 10px;
  }

  #shopify-section-{{ section.id }} .knr-review__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 34px;
    color: var(--review-gold);
    font-size: 11px;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .knr-review__stars {
    display: inline-flex;
    gap: 2px;
  }

  #shopify-section-{{ section.id }} .knr-review__stars svg {
    width: 11px;
    height: 11px;
    display: block;
  }

  #shopify-section-{{ section.id }} .knr-review__name {
    color: var(--review-muted);
    font-size: 10px;
    line-height: 1;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .knr-review__body {
    max-width: {{ section.settings.quote_width }}px;
    margin: 0 auto;
    color: var(--review-ink);
    font-size: {{ section.settings.quote_size }}px;
       font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 32px;
    line-height: 40px;
    letter-spacing: -0.04em;
    text-align: center;
    vertical-align: middle;
  }

  #shopify-section-{{ section.id }} .knr-reviews__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 34px;
    margin-top: 54px;
  }

  #shopify-section-{{ section.id }} .knr-reviews__arrow {
    width: 24px;
    height: 24px;
    border: 0;
    background: transparent;
    color: var(--review-ink);
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity .18s ease, transform .18s ease;
  }

  #shopify-section-{{ section.id }} .knr-reviews__arrow:hover {
    opacity: .55;
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .knr-reviews__arrow svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
  }

  #shopify-section-{{ section.id }} .knr-reviews__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 26px;
  }

  #shopify-section-{{ section.id }} .knr-reviews__dot {
    width: 5px;
    height: 5px;
    border: 0;
    border-radius: 50%;
    background: var(--review-muted);
    opacity: .38;
    padding: 0;
    cursor: pointer;
    transition: opacity .2s ease, transform .2s ease;
  }

  #shopify-section-{{ section.id }} .knr-reviews__dot.is-active {
    opacity: 1;
    transform: scale(1.25);
  }

  @media (max-width: 760px) {
    #shopify-section-{{ section.id }} .knr-reviews {
      padding: {{ section.settings.mobile_padding_top }}px 20px {{ section.settings.mobile_padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .knr-review__meta {
      margin-bottom: 24px;
    }

    #shopify-section-{{ section.id }} .knr-review__body {
      font-size: {{ section.settings.mobile_quote_size }}px;
      line-height: 1.38;
    }

    #shopify-section-{{ section.id }} .knr-reviews__controls {
      margin-top: 36px;
      gap: 28px;
    }
     #shopify-section-{{ section.id }} .knr-review__body {
    font-size: 24px;
    line-height: 1.38;
    border-left: unset;
  
  }
  }
</style>

{%- assign review_blocks = section.blocks | where: 'type', 'review' -%}

<section class="knr-reviews" data-knr-reviews>
  <div class="knr-reviews__inner">
    {%- if section.settings.show_title and section.settings.title != blank -%}
      <h2 class="knr-reviews__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if review_blocks.size > 0 -%}
      <div class="knr-reviews__viewport">
        <div class="knr-reviews__track">
          {%- for block in review_blocks -%}
            <article class="knr-review" {{ block.shopify_attributes }}>
              <div class="knr-review__meta">
                <span class="knr-review__stars" aria-label="{{ block.settings.stars }} étoiles">
                  {%- for i in (1..5) -%}
                    <svg viewBox="0 0 12 12" fill="{% if i <= block.settings.stars %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
                      <path d="M6 1l1.4 2.8 3.1.5-2.3 2.2.6 3.1L6 8.1 3.2 9.6l.6-3.1L1.5 4.3l3.1-.5z"/>
                    </svg>
                  {%- endfor -%}
                </span>
                {%- if block.settings.name != blank -%}
                  <span class="knr-review__name">{{ block.settings.name }}</span>
                {%- endif -%}
              </div>

              <blockquote class="knr-review__body">{{ block.settings.body }}</blockquote>
            </article>
          {%- endfor -%}
        </div>
      </div>

      {%- if review_blocks.size > 1 and section.settings.show_arrows -%}
        <div class="knr-reviews__controls">
          <button type="button" class="knr-reviews__arrow knr-reviews__arrow--prev" aria-label="Avis précédent">
            <svg viewBox="0 0 18 18"><path d="M11.5 3.5 6 9l5.5 5.5"/></svg>
          </button>
          <button type="button" class="knr-reviews__arrow knr-reviews__arrow--next" aria-label="Avis suivant">
            <svg viewBox="0 0 18 18"><path d="M6.5 3.5 12 9l-5.5 5.5"/></svg>
          </button>
        </div>
      {%- endif -%}

      {%- if review_blocks.size > 1 and section.settings.show_dots -%}
        <div class="knr-reviews__dots">
          {%- for block in review_blocks -%}
            <button type="button" class="knr-reviews__dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Afficher l'avis {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

<script>
  (() => {
    const section = document.currentScript.previousElementSibling;
    if (!section?.matches('[data-knr-reviews]')) return;

    const track = section.querySelector('.knr-reviews__track');
    const slides = [...section.querySelectorAll('.knr-review')];
    const dots = [...section.querySelectorAll('.knr-reviews__dot')];
    const prev = section.querySelector('.knr-reviews__arrow--prev');
    const next = section.querySelector('.knr-reviews__arrow--next');
    if (!track || slides.length < 2) return;

    let current = 0;

    const goTo = index => {
      current = (index + slides.length) % slides.length;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === current));
    };

    prev?.addEventListener('click', () => goTo(current - 1));
    next?.addEventListener('click', () => goTo(current + 1));
    dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));
  })();
</script>

{% schema %}
{
  "name": "KNR Reviews",
  "settings": [
    { "type": "checkbox", "id": "show_title", "label": "Show title", "default": false },
    { "type": "text", "id": "title", "label": "Title", "default": "Avis clients" },
