      ]
    }
  ],
  "presets": [
    {
      "name": "KNR Reviews",
      "blocks": [
        { "type": "review", "settings": { "name": "Clara T.", "verified": true, "date": "12 jan. 2025", "stars": 5, "headline": "Incroyable résultat", "body": "J'utilise ce sérum depuis trois mois et la différence est saisissante. Mes rides d'expression se sont considérablement atténuées et mon teint a retrouvé une luminosité que je n'avais plus depuis des années. Une texture soyeuse qui pénètre instantanément. Je ne peux plus m'en passer." } },
