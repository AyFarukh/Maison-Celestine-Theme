{% comment %}
  Maison Célestine — Custom Footer
  4-column desktop · accordion mobile · large brand logo · full schema customization
{% endcomment %}

{%- liquid
  assign sid = section.id
  assign menu_col_count = 0
  for block in section.blocks
    if block.type == 'menu_column'
      assign menu_col_count = menu_col_count | plus: 1
    endif
  endfor
-%}


<style>
/* ============================================================
   MC Footer — scoped styles
   ============================================================ */
.mc-footer {
  background-color: {{ section.settings.background_color }};
  color: {{ section.settings.text_color }};
  font-family: inherit;
}
.mc-footer *,
.mc-footer *::before,
.mc-footer *::after { box-sizing: border-box; }

/* Container */
.mc-footer__container {
  max-width: {% if section.settings.full_width %}100%{% else %}{{ section.settings.max_width }}px{% endif %};
  margin-left: auto;
  margin-right: auto;
  padding-left: {{ section.settings.padding_sides_desktop }}px;
  padding-right: {{ section.settings.padding_sides_desktop }}px;
}

/* Main columns wrapper */
.mc-footer__main {
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}

.mc-footer__columns {
  display: grid;
  grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
  gap: {{ section.settings.column_gap }}px;
  align-items: start;
}

/* ---- Column headings (desktop) ---- */
.mc-footer__col-heading-desktop {
    text-transform: uppercase;
    color: #1a1a1a;
    margin: 0 0 16px;
    display: block;
    font-family: Inter;
    font-weight: 400;
    font-size: 12px;
    line-height: 20px;
    letter-spacing: -2%;
    vertical-align: middle;
}

/* ---- Accordion button (mobile only) ---- */
.mc-footer__accordion-btn {
  display: none;
  background: none;
  border: none;
  padding: 18px 0;
  width: 100%;
  text-align: left;
  cursor: pointer;
  align-items: center;
  justify-content: space-between;
  color: {{ section.settings.text_color }};
  font-family: inherit;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.mc-footer__chevron {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  transition: transform 0.3s ease;
}
.mc-footer__accordion-btn[aria-expanded="true"] .mc-footer__chevron {
  transform: rotate(180deg);
}

/* ---- Menu content ---- */
.mc-footer__menu-content {
  /* Desktop: always open — no height restriction */
}
.mc-footer__nav-list {
  list-style: none;
  margin: 0;
  padding: 0 0 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.mc-footer__nav-link {
    color: #1a1a1a;
    text-decoration: none;
    transition: color 0.15s ease;
    font-family: Inter;
    font-weight: 400;
    font-size: 12px;
    line-height: 20px;
    letter-spacing: -2%;
    vertical-align: middle;
}
.mc-footer__nav-link:hover { color: {{ section.settings.link_hover_color }}; }

/* ---- About column ---- */
.mc-footer__about-heading {
    text-transform: uppercase;
    color: #1a1a1a;
    margin: 0 0 16px;
    font-family: Inter;
    font-weight: 400;
    font-size: 12px;
    line-height: 20px;
    letter-spacing: -2%;
    vertical-align: middle;
}
.mc-footer__about-text {
    color: #1a1a1a;
    margin: 0 0 24px;
    font-family: Inter;
    font-weight: 400;
    font-size: 12px;
    line-height: 20px;
    letter-spacing: -2%;
    vertical-align: middle;
}
.mc-footer__cert-image {
  margin-bottom: 10px;
}
.mc-footer__cert-image img {
  display: block;
  height: auto;
}
.mc-footer__cert-text {
  font-size: 12px;
  line-height: 1.45;
  color: {{ section.settings.text_color }};
  margin: 0 0 20px;
}
.mc-footer__cert-divider {
  border: none;
  border-top: 1px solid {{ section.settings.border_color }};
  margin: 0 0 16px;
}
.mc-footer__cert-link {
  font-size: 13px;
  color: {{ section.settings.text_color }};
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
  transition: color 0.15s ease;
}
.mc-footer__cert-link:hover { color: {{ section.settings.link_hover_color }}; }

/* ============================================================
   Logo bar
   ============================================================ */
.mc-footer__logo-bar {
  width: 100%;
  overflow: hidden;
  margin-top: {{ section.settings.logo_spacing }}px;
  line-height: 1;
      display: flex;
    justify-content: center;
}
.mc-footer__logo-text {
  display: block;
  font-size: {{ section.settings.logo_font_size_desktop }}vw;
  font-weight: 300;
  letter-spacing: {{ section.settings.logo_letter_spacing | times: 0.001 }}em;
  text-align: {{ section.settings.logo_alignment }};
  color: {{ section.settings.text_color }};
  line-height: 0.88;
  white-space: nowrap;
  text-transform: lowercase;
}
.mc-footer__logo-image {
  text-align: {{ section.settings.logo_alignment }};
}
.mc-footer__logo-image img {
  max-width: 100%;
  height: auto;
  display: inline-block;
}

/* ============================================================
   Bottom bar
   ============================================================ */
.mc-footer__bottom {
  border-top: 1px solid {{ section.settings.border_color }};
  padding: 20px 0;
}
.mc-footer__bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}

/* Localization selects */
.mc-footer__localization {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
}
.mc-footer__loc-form { display: inline-flex; }
.mc-footer__select-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
}
.mc-footer__select {
  appearance: none;
  -webkit-appearance: none;
  background: transparent;
  border: none;
  padding: 4px 22px 4px 0;
  font-size: 13px;
  font-family: inherit;
  color: {{ section.settings.text_color }};
  cursor: pointer;
  outline: none;
  line-height: 1.4;
}
.mc-footer__select:hover { color: {{ section.settings.link_hover_color }}; }
.mc-footer__select-icon {
  position: absolute;
  right: 4px;
  pointer-events: none;
  display: flex;
  align-items: center;
  color: {{ section.settings.text_color }};
}

/* Copyright */
.mc-footer__copyright {
  font-size: 12px;
  color: {{ section.settings.text_color }};
  text-align: center;
}
.mc-footer__copyright p { margin: 0; }

/* Social icons */
.mc-footer__social {
  display: flex;
  align-items: center;
  gap: 16px;
}
.mc-footer__social-link {
  display: flex;
  align-items: center;
  color: {{ section.settings.text_color }};
  text-decoration: none;
  transition: color 0.15s ease;
}
.mc-footer__social-link:hover { color: {{ section.settings.link_hover_color }}; }
.mc-footer__social-link svg {
  width: 18px;
  height: 18px;
  fill: currentColor;
  display: block;
}

/* ============================================================
   MOBILE  ≤ 767px
   ============================================================ */
@media (max-width: 767px) {
  .mc-footer__container {
    padding-left: {{ section.settings.padding_sides_mobile }}px;
    padding-right: {{ section.settings.padding_sides_mobile }}px;
  }
  .mc-footer__main {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  /* Stack columns */
  .mc-footer__columns {
    grid-template-columns: 1fr;
    gap: 0;
  }

  /* Hide desktop heading, show accordion btn */
  .mc-footer__col--menu .mc-footer__col-heading-desktop { display: none; }
  .mc-footer__accordion-btn { display: flex; }

  /* Borders for accordion rows */
  .mc-footer__col--menu {
    border-top: 1px solid {{ section.settings.accordion_border_color }};
  }
  .mc-footer__col--menu-last {
    border-bottom: 1px solid {{ section.settings.accordion_border_color }};
  }

  /* Collapsed by default */
  .mc-footer__menu-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }
  .mc-footer__col--menu.mc-open .mc-footer__menu-content {
    max-height: 600px;
  }

  /* About column */
  .mc-footer__col--about {
    padding-top: 36px;
  }

  /* Logo */
  .mc-footer__logo-text {
    font-size: {{ section.settings.logo_font_size_mobile }}vw;
  }

  /* Bottom bar */
  .mc-footer__bottom-inner {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
  }
  .mc-footer__localization { justify-content: center; }
  .mc-footer__social { justify-content: center; }
}
p.mc-footer__cert-text {
    font-family: Inter;
    font-weight: 400;
    font-size: 12px;
    line-height: 20px;
    letter-spacing: -2%;
    vertical-align: middle;
}
</style>

<footer class="mc-footer" role="contentinfo">

  {%- comment -%}──────────────── MAIN COLUMNS ────────────────{%- endcomment -%}
  <div class="mc-footer__main">
    <div class="mc-footer__container">
      <div class="mc-footer__columns">

        {%- assign menu_col_idx = 0 -%}
        {%- for block in section.blocks -%}

          {%- if block.type == 'menu_column' -%}
            {%- assign menu_col_idx = menu_col_idx | plus: 1 -%}
            {%- assign is_last_menu = false -%}
            {%- if menu_col_idx == menu_col_count -%}
              {%- assign is_last_menu = true -%}
            {%- endif -%}

            <div
              class="mc-footer__col mc-footer__col--menu{% if is_last_menu %} mc-footer__col--menu-last{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} Desktop heading {%- endcomment -%}
              <span class="mc-footer__col-heading-desktop" aria-hidden="true">
                {{- block.settings.heading | default: 'Menu' -}}
              </span>

              {%- comment -%} Mobile accordion toggle {%- endcomment -%}
              <button
                class="mc-footer__accordion-btn"
                type="button"
                aria-expanded="false"
                aria-controls="mc-col-{{ block.id }}"
              >
                <span>{{- block.settings.heading | default: 'Menu' -}}</span>
                <span class="mc-footer__chevron" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </button>

              {%- comment -%} Menu links {%- endcomment -%}
              <div class="mc-footer__menu-content" id="mc-col-{{ block.id }}">
                {%- if block.settings.menu != blank -%}
                  <nav aria-label="{{ block.settings.heading | escape }}">
                    <ul class="mc-footer__nav-list">
                      {%- for link in linklists[block.settings.menu].links -%}
                        <li>
                          <a
                            href="{{ link.url }}"
                            class="mc-footer__nav-link"
                            {% if link.active %}aria-current="page"{% endif %}
                          >
                            {{- link.title | escape -}}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </nav>
                {%- endif -%}
              </div>
            </div>

          {%- elsif block.type == 'about_column' -%}

            <div class="mc-footer__col mc-footer__col--about" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="mc-footer__about-heading">{{- block.settings.heading -}}</h3>
              {%- endif -%}

              {%- if block.settings.about_text != blank -%}
                <div class="mc-footer__about-text">{{- block.settings.about_text -}}</div>
              {%- endif -%}

              {%- if block.settings.cert_image != blank -%}
                <div class="mc-footer__cert-image">
                  <img
                    src="{{ block.settings.cert_image | image_url: width: 300 }}"
                    alt="{{ block.settings.cert_alt | default: 'Certification' | escape }}"
                    width="{{ block.settings.cert_image_width }}"
                    loading="lazy"
                    style="width: {{ block.settings.cert_image_width }}px; height: auto;"
                  >
                </div>
              {%- endif -%}

              {%- if block.settings.cert_text != blank -%}
                <p class="mc-footer__cert-text">{{- block.settings.cert_text -}}</p>
              {%- endif -%}

              {%- if block.settings.cert_link_url != blank -%}
                <hr class="mc-footer__cert-divider">
                <a
                  href="{{ block.settings.cert_link_url }}"
                  class="mc-footer__cert-link"
                  {% if block.settings.cert_link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                >
                  {{- block.settings.cert_link_text | default: 'Voir le certificat' -}}
                </a>
              {%- endif -%}
            </div>

          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>
  </div>

  {%- comment -%}──────────────── LARGE LOGO BAR ────────────────{%- endcomment -%}
  <div class="mc-footer__logo-bar">
    {%- if section.settings.logo_type == 'image' and section.settings.logo_image != blank -%}
      <div class="mc-footer__logo-image">
        <img
          src="{{ section.settings.logo_image | image_url: width: 2000 }}"
          alt="{{ section.settings.logo_alt | default: shop.name | escape }}"
          loading="lazy"
          style="max-width: {{ section.settings.logo_image_max_width }}%;"
        >
      </div>
    {%- else -%}
      <span class="mc-footer__logo-text">
        {{- section.settings.logo_text | default: shop.name -}}
      </span>
    {%- endif -%}
  </div>

  {%- comment -%}──────────────── BOTTOM BAR ────────────────{%- endcomment -%}
  <div class="mc-footer__bottom">
    <div class="mc-footer__container mc-footer__bottom-inner">

      {%- comment -%} Country + Language selectors {%- endcomment -%}
      <div class="mc-footer__localization">
        {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
          {%- form 'localization', id: 'mc-country-{{ sid }}', class: 'mc-footer__loc-form' -%}
            <div class="mc-footer__select-wrap">
              <select name="country_code" class="mc-footer__select" onchange="this.form.submit()">
                {%- for country in localization.available_countries -%}
                  <option
                    value="{{ country.iso_code }}"
                    {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
                  >
                    {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol -}})
                  </option>
                {%- endfor -%}
              </select>
              <span class="mc-footer__select-icon" aria-hidden="true">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
            </div>
          {%- endform -%}
        {%- endif -%}

        {%- if section.settings.show_language_selector and localization.available_languages.size > 1 -%}
          {%- form 'localization', id: 'mc-lang-{{ sid }}', class: 'mc-footer__loc-form' -%}
            <div class="mc-footer__select-wrap">
              <select name="locale_code" class="mc-footer__select" onchange="this.form.submit()">
                {%- for language in localization.available_languages -%}
                  <option
                    value="{{ language.iso_code }}"
                    {% if language.iso_code == localization.language.iso_code %}selected{% endif %}
                  >
                    {{- language.endonym_name | capitalize -}}
                  </option>
                {%- endfor -%}
              </select>
              <span class="mc-footer__select-icon" aria-hidden="true">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
            </div>
          {%- endform -%}
        {%- endif -%}
      </div>

      {%- comment -%} Copyright {%- endcomment -%}
      <div class="mc-footer__copyright">
        {%- if section.settings.copyright_text != blank -%}
          <p>{{ section.settings.copyright_text }}</p>
        {%- else -%}
          <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.</p>
        {%- endif -%}
      </div>

      {%- comment -%} Social icons {%- endcomment -%}
      <div class="mc-footer__social">
        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" class="mc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="mc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.tiktok_url != blank -%}
          <a href="{{ section.settings.tiktok_url }}" class="mc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.77a4.85 4.85 0 01-1.01-.08z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.linkedin_url != blank -%}
          <a href="{{ section.settings.linkedin_url }}" class="mc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.youtube_url != blank -%}
          <a href="{{ section.settings.youtube_url }}" class="mc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.pinterest_url != blank -%}
          <a href="{{ section.settings.pinterest_url }}" class="mc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
