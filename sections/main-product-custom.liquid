<section class="vit-product" style="--top-bg: {{ section.settings.top_bg }}; --thumb-bg: {{ section.settings.thumb_bg }};">
  <div class="vit-product__media">
    <div class="vit-product__hero">
      {% assign featured_image = product.selected_or_first_available_variant.featured_image | default: product.featured_image %}
      {% if featured_image %}
        <img
          id="VitMainImage-{{ section.id }}"
          src="{{ featured_image | image_url: width: 1400 }}"
          alt="{{ featured_image.alt | escape }}"
          loading="eager"
        >
      {% endif %}
    </div>

    <div class="vit-product__thumbs">
      {% for media in product.media limit: 3 %}
        {% if media.media_type == 'image' %}
          <button
            class="vit-product__thumb {% if forloop.first %}is-active{% endif %}"
            type="button"
            data-image="{{ media | image_url: width: 1400 }}"
          >
            <img src="{{ media | image_url: width: 700 }}" alt="{{ media.alt | escape }}">
            <span>+</span>
          </button>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="vit-product__info-wrap">
    <div class="vit-product__info">
      {% for block in section.blocks %}
        {% case block.type %}

          {% when 'breadcrumb' %}
            <div class="vit-product__breadcrumb" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {% when 'badges' %}
            <div class="vit-product__badges" {{ block.shopify_attributes }}>
              {% if block.settings.badge_1 != blank %}<span>{{ block.settings.badge_1 }}</span>{% endif %}
              {% if block.settings.badge_2 != blank %}<span>{{ block.settings.badge_2 }}</span>{% endif %}
            </div>

          {% when 'title_price' %}
            <div class="vit-product__title-row" {{ block.shopify_attributes }}>
              <h1>{{ product.title }}</h1>
              <div class="vit-product__price">
                <strong>{{ product.price | money }}</strong>
                {% if product.compare_at_price > product.price %}
                  <s>{{ product.compare_at_price | money }}</s>
                {% endif %}
                <small>{{ block.settings.price_note }}</small>
              </div>
            </div>

          {% when 'rating' %}
            <div class="vit-product__rating" {{ block.shopify_attributes }}>
              ★★★★★ <span>{{ block.settings.rating_text }}</span>
            </div>

          {% when 'vendor_text' %}
            <div class="vit-product__vendor" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {% when 'description' %}
            <div class="vit-product__desc" {{ block.shopify_attributes }}>
              {{ product.description | strip_html | truncatewords: 35 }}
            </div>

          {% when 'variant_picker' %}
            <div class="vit-product__variants" {{ block.shopify_attributes }}>
              {% unless product.has_only_default_variant %}
                {% for option in product.options_with_values %}
                  <label>{{ option.name }}</label>
                  <div class="vit-product__option-list">
                    {% for value in option.values %}
                      <button
                        type="button"
                        class="{% if forloop.first %}is-active{% endif %}"
                      >
                        {{ value }}
                      </button>
                    {% endfor %}
                  </div>
                {% endfor %}
              {% endunless %}
            </div>

          {% when 'buy_button' %}
            <form method="post" action="/cart/add" {{ block.shopify_attributes }}>
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button class="vit-product__cart" type="submit">
                {{ block.settings.button_label }}
              </button>
              {% if block.settings.stock_text != blank %}
                <p class="vit-product__stock">{{ block.settings.stock_text }}</p>
              {% endif %}
            </form>

          {% when 'accordion' %}
            <details class="vit-product__accordion" {% if block.settings.open %}open{% endif %} {{ block.shopify_attributes }}>
              <summary>{{ block.settings.title }}</summary>
              <div>{{ block.settings.content }}</div>
            </details>

          {% when 'addon_slider' %}
            <div class="vit-product__addons" {{ block.shopify_attributes }}>
              <div class="vit-product__addons-head">
                <span>{{ block.settings.heading }}</span>
                <button type="button" class="vit-addon-next">›</button>
              </div>

              <div class="vit-product__addon-track">
                {% assign addon_products = product.metafields.custom.addon_products.value %}
                {% if addon_products != blank %}
                  {% for addon in addon_products %}
                    <div class="vit-product__addon">
                      <button>+</button>
                      <img src="{{ addon.featured_image | image_url: width: 400 }}" alt="{{ addon.title | escape }}">
                      <div>
                        <span>{{ addon.title }}</span>
                        <strong>{{ addon.price | money }}</strong>
                      </div>
                    </div>
                  {% endfor %}
                {% endif %}
              </div>
            </div>

        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .vit-product {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    background: var(--top-bg);
    min-height: 100vh;
  }

  .vit-product__media {
    display: grid;
    grid-template-rows: 58vh auto;
  }

  .vit-product__hero {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--top-bg);
    padding: 48px;
  }

  .vit-product__hero img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    max-height: 620px;
  }

  .vit-product__thumbs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
    background: var(--thumb-bg);
    padding: 6px;
  }

  .vit-product__thumb {
    position: relative;
    border: 0;
    padding: 0;
    background: #f8f6ef;
    cursor: pointer;
    overflow: hidden;
  }

  .vit-product__thumb img {
    width: 100%;
    height: 410px;
    object-fit: cover;
    display: block;
  }

  .vit-product__thumb span {
    position: absolute;
    right: 18px;
    bottom: 18px;
    color: #fff;
    font-size: 28px;
    line-height: 1;
  }

  .vit-product__info-wrap {
    background: var(--top-bg);
    padding: 22px 36px 28px 0;
  }

  .vit-product__info {
    background: #fff;
    padding: 52px 46px 28px;
    min-height: calc(100vh - 44px);
  }

  .vit-product__breadcrumb {
    font-size: 11px;
    color: #b39c7f;
    margin-bottom: 32px;
  }

  .vit-product__badges {
    display: flex;
    gap: 6px;
    margin-bottom: 28px;
  }

  .vit-product__badges span {
    border: 1px solid #111;
    font-size: 12px;
    padding: 3px 7px;
    line-height: 1;
  }

  .vit-product__title-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: start;
    margin-bottom: 28px;
  }

  .vit-product__title-row h1 {
    margin: 0;
    font-size: 34px;
    line-height: .92;
    letter-spacing: -.02em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .vit-product__price {
    text-align: left;
    color: #b39c7f;
  }

  .vit-product__price strong {
    display: block;
    color: #111;
    font-size: 30px;
    font-weight: 500;
  }

  .vit-product__price s,
  .vit-product__price small {
    display: block;
    font-size: 12px;
    margin-top: 8px;
  }

  .vit-product__rating {
    color: #b99a65;
    text-align: right;
    font-size: 18px;
    margin-bottom: 26px;
  }

  .vit-product__rating span {
    color: #b39c7f;
    font-size: 11px;
    margin-left: 8px;
  }

  .vit-product__vendor {
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 24px;
  }

  .vit-product__desc {
    font-size: 14px;
    line-height: 1.7;
    margin-bottom: 34px;
  }

  .vit-product__variants label {
    display: block;
    font-size: 13px;
    margin-bottom: 20px;
  }

  .vit-product__option-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    margin-bottom: 24px;
  }

  .vit-product__option-list button {
    border: 0;
    border-bottom: 1px solid #111;
    background: transparent;
    padding: 0 0 10px;
    font-size: 13px;
    cursor: pointer;
  }

  .vit-product__option-list button:not(.is-active) {
    border-color: #ddd;
  }

  .vit-product__cart {
    width: 100%;
    border: 0;
    background: #000;
    color: #fff;
    height: 54px;
    font-size: 13px;
    cursor: pointer;
    margin-top: 10px;
  }

  .vit-product__stock {
    text-align: center;
    font-size: 11px;
    margin: 22px 0 24px;
  }

  .vit-product__accordion {
    border-top: 1px solid #d8d8d8;
    padding: 20px 0;
    font-size: 13px;
  }

  .vit-product__accordion:last-of-type {
    border-bottom: 1px solid #d8d8d8;
  }

  .vit-product__accordion summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
  }

  .vit-product__accordion summary::after {
    content: "+";
  }

  .vit-product__accordion[open] summary::after {
    content: "−";
  }

  .vit-product__accordion div {
    margin-top: 18px;
    line-height: 1.7;
  }

  .vit-product__addons {
    margin-top: 34px;
    overflow: hidden;
  }

  .vit-product__addons-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-transform: uppercase;
    font-size: 13px;
    margin-bottom: 20px;
  }

  .vit-addon-next {
    border: 0;
    background: transparent;
    font-size: 30px;
    cursor: pointer;
  }

  .vit-product__addon-track {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .vit-product__addon-track::-webkit-scrollbar {
    display: none;
  }

  .vit-product__addon {
    min-width: 132px;
    scroll-snap-align: start;
    position: relative;
  }

  .vit-product__addon button {
    position: absolute;
    left: 8px;
    bottom: 42px;
    z-index: 2;
    width: 20px;
    height: 20px;
    border: 0;
    background: #fff;
    cursor: pointer;
  }

  .vit-product__addon img {
    width: 132px;
    height: 168px;
    object-fit: cover;
    background: #eee8dc;
    display: block;
  }

  .vit-product__addon div {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    font-size: 10px;
    margin-top: 10px;
  }

  .vit-product__addon strong {
    font-weight: 500;
  }

  @media screen and (max-width: 749px) {
    .vit-product {
      display: block;
      background: var(--top-bg);
    }

    .vit-product__media {
      display: block;
    }

    .vit-product__hero {
      height: 330px;
      padding: 28px 20px 44px;
    }

    .vit-product__thumbs {
      display: none;
    }

    .vit-product__info-wrap {
      padding: 0 12px 24px;
      margin-top: -18px;
      background: var(--top-bg);
    }

    .vit-product__info {
      padding: 26px 18px 30px;
      min-height: auto;
    }

    .vit-product__breadcrumb {
      display: none;
    }

    .vit-product__title-row {
      grid-template-columns: 1fr auto;
      gap: 14px;
      margin-bottom: 18px;
    }

    .vit-product__title-row h1 {
      font-size: 20px;
      line-height: 1.15;
    }

    .vit-product__price strong {
      font-size: 18px;
    }

    .vit-product__rating {
      text-align: left;
      font-size: 13px;
    }

    .vit-product__desc,
    .vit-product__vendor {
      font-size: 12px;
    }

    .vit-product__cart {
      height: 48px;
    }

    .vit-product__addon {
      min-width: 118px;
    }

    .vit-product__addon img {
      width: 118px;
      height: 150px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('.vit-product');
    if (!section) return;

    const mainImage = section.querySelector('#VitMainImage-{{ section.id }}');
    const thumbs = section.querySelectorAll('.vit-product__thumb');

    thumbs.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        if (!mainImage) return;

        mainImage.src = thumb.dataset.image;

        thumbs.forEach(t => t.classList.remove('is-active'));
        thumb.classList.add('is-active');
      });
    });

    const addonTrack = section.querySelector('.vit-product__addon-track');
    const nextBtn = section.querySelector('.vit-addon-next');

    if (addonTrack && nextBtn) {
      nextBtn.addEventListener('click', function () {
        addonTrack.scrollBy({
          left: 160,
          behavior: 'smooth'
        });
      });
    }
  });
</script>

