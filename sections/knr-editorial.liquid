{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'knr-editorial-form-' | append: section.id
-%}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 5;
  }

  #shopify-section-{{ section.id }} .knr-editorial {
    --knr-editorial-height: {{ section.settings.desktop_height }}px;
    --knr-editorial-bg: {{ section.settings.fallback_bg }};
    --knr-editorial-text: {{ section.settings.text_color }};
    --knr-editorial-card-bg: {{ section.settings.card_bg }};
    --knr-editorial-card-text: {{ section.settings.card_text_color }};
    --knr-editorial-card-border: {{ section.settings.card_border_color }};
    position: relative;
    min-height: var(--knr-editorial-height);
    background: var(--knr-editorial-bg);
    color: var(--knr-editorial-text);
    font-family: var(--knr-font);
    overflow: visible;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .knr-editorial__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .knr-editorial__bg img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
    opacity: {{ section.settings.image_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .knr-editorial__bg-img--mobile {
    display: none;
  }

  #shopify-section-{{ section.id }} .knr-editorial__bg:not(.knr-editorial__bg--has-desktop) .knr-editorial__bg-img--mobile {
    display: block;
  }

  #shopify-section-{{ section.id }} .knr-editorial__shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    pointer-events: none;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .knr-editorial__inner {
    position: relative;
    z-index: 2;
    min-height: var(--knr-editorial-height);
    display: grid;
    grid-template-columns: minmax(180px, 1fr) minmax(360px, {{ section.settings.text_width }}px);
    align-items: center;
    gap: {{ section.settings.column_gap }}px;
    max-width: {{ section.settings.section_max_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px {{ section.settings.side_padding }}px {{ section.settings.padding_bottom }}px;
    margin-top:80px;
  }

  #shopify-section-{{ section.id }} .knr-editorial__note {
    align-self: center;
    max-width: {{ section.settings.note_width }}px;
    color: rgba(250, 249, 247, .86);
    font-size: {{ section.settings.note_size }}px;
    line-height: 1.5;
    margin-top: {{ section.settings.note_offset | minus: 180 }}px;

  }

  #shopify-section-{{ section.id }} .knr-editorial__note p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .knr-editorial__note::after {
    content: '';
    display: block;
    width: 20px;
    height: 1px;
    margin-top: 12px;
    background: currentColor;
    opacity: .72;
  }

  #shopify-section-{{ section.id }} .knr-editorial__content {
    align-self: center;
  }

  #shopify-section-{{ section.id }} .knr-editorial__text {
    color: var(--knr-editorial-text);
    font-size: {{ section.settings.body_size }}px;
  
    margin: 0;
        margin: 0;
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-style: normal;
  
    line-height: 40px;
    letter-spacing: -0.04em;
    vertical-align: middle;
  }

  #shopify-section-{{ section.id }} .knr-editorial__author {
    color: rgba(250, 249, 247, .86);
    font-size: {{ section.settings.author_size }}px;
    line-height: 1.4;
    margin: {{ section.settings.author_gap }}px 0 0;
  }

  #shopify-section-{{ section.id }} .knr-editorial__product-card {
    position: absolute;
    right: max({{ section.settings.side_padding }}px, calc((100vw - {{ section.settings.section_max_width }}px) / 2 + {{ section.settings.side_padding }}px));
    bottom: 0;
    z-index: 20;
    transform: translateY(50%);
    {% comment %} width: min({{ section.settings.card_width }}px, calc(100vw - 48px)); {% endcomment %}
    display: grid;
    grid-template-columns: {{ section.settings.card_image_width }}px minmax(0, 1fr) {{ section.settings.button_width }}px;
    gap: 18px;
    align-items: stretch;
    background: var(--knr-editorial-card-bg);
    color: var(--knr-editorial-card-text);
    border: 1px solid var(--knr-editorial-card-border);
    padding: {{ section.settings.card_padding }}px;
    box-shadow: 0 14px 40px rgba(0, 0, 0, .08);
  }

  #shopify-section-{{ section.id }} .knr-editorial__product-image {
    height: 100%;
    min-height: 96px;
    background: #f2eee7;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .knr-editorial__product-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .knr-editorial__product-info {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .knr-editorial__product-name {
    color: var(--knr-editorial-card-text);
    font-size: {{ section.settings.product_title_size }}px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: 0;
    text-transform: uppercase;
    margin: 0 0 16px;
  }

  #shopify-section-{{ section.id }} .knr-editorial__variant-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0 0 16px;
    color: var(--knr-editorial-card-text);
    font-size: {{ section.settings.option_size }}px;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .knr-editorial__variant-option {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    border-bottom: 1px solid transparent;
    color: inherit;
    cursor: pointer;
    font: inherit;
    line-height: inherit;
    padding: 0 0 2px;
    transition: opacity .18s ease, border-color .18s ease;
  }

  #shopify-section-{{ section.id }} .knr-editorial__variant-option.is-selected {
    border-bottom-color: currentColor;
  }

  #shopify-section-{{ section.id }} .knr-editorial__variant-option[disabled] {
    opacity: .34;
    cursor: not-allowed;
  }

  #shopify-section-{{ section.id }} .knr-editorial__product-price {
    color: var(--knr-editorial-card-text);
    font-size: {{ section.settings.price_size }}px;
    line-height: 1.2;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .knr-editorial__product-form {
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .knr-editorial__atc {
    width: 100%;
   
    min-height: 56px;
    border: 0;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    font-family: var(--knr-font);
    font-size: {{ section.settings.button_text_size }}px;
    line-height: 1.2;
    padding: 14px 18px;
    transition: opacity .18s ease;
  }

  #shopify-section-{{ section.id }} .knr-editorial__atc:hover {
    opacity: .82;
  }

  #shopify-section-{{ section.id }} .knr-editorial__atc[disabled] {
    cursor: not-allowed;
    {% comment %} opacity: .45;
    opacity: .45; */ {% endcomment %}
    background: #000;
  }

  #shopify-section-{{ section.id }} .knr-editorial__fallback {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 42% 38%, rgba(250, 249, 247, .28), transparent 28%),
      linear-gradient(135deg, rgba(250, 249, 247, .18), rgba(28, 28, 26, .24)),
      var(--knr-editorial-bg);
  }

  @media (max-width: 980px) {
    #shopify-section-{{ section.id }} .knr-editorial {
      min-height: max({{ section.settings.mobile_height }}px, 100svh);
    }

    #shopify-section-{{ section.id }} .knr-editorial__bg--has-mobile .knr-editorial__bg-img--desktop {
      display: none;
    }

    #shopify-section-{{ section.id }} .knr-editorial__bg--has-mobile .knr-editorial__bg-img--mobile {
      display: block;
      object-position: {{ section.settings.mobile_image_position }};
      opacity: {{ section.settings.mobile_image_opacity | divided_by: 100.0 }};
    }

    #shopify-section-{{ section.id }} .knr-editorial__inner {
      min-height: max({{ section.settings.mobile_height }}px, 100svh);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 0;
      padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_side_padding }}px {{ section.settings.mobile_padding_bottom }}px;
      margin-top: 0;
    }

    #shopify-section-{{ section.id }} .knr-editorial__note {
      max-width: min(78vw, 320px);
      margin-top: 0;
      font-size: {{ section.settings.mobile_note_size }}px;
      line-height: 1.45;
      color: rgba(250, 249, 247, .94);
      margin-bottom: auto;
    }

    #shopify-section-{{ section.id }} .knr-editorial__content {
      max-width: 100%;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .knr-editorial__text {
      max-width: min(92vw, 520px);
      font-size: {{ section.settings.mobile_body_size }}px;
      line-height: 1.08;
      letter-spacing: -0.045em;
      font-weight: 400;
    }

    #shopify-section-{{ section.id }} .knr-editorial__author {
      margin-top: 22px;
      font-size: max({{ section.settings.author_size }}px, 12px);
      color: rgba(250, 249, 247, .94);
    }

    #shopify-section-{{ section.id }} .knr-editorial__product-card {
      display: none;
    }
  }

  @media (max-width: 640px) {
    #shopify-section-{{ section.id }} .knr-editorial__bg img {
      object-position: {{ section.settings.mobile_image_position }};
      opacity: {{ section.settings.mobile_image_opacity | divided_by: 100.0 }};
    }

    #shopify-section-{{ section.id }} .knr-editorial__shade {
      background:
        linear-gradient(
          180deg,
          rgba(0, 0, 0, {{ section.settings.mobile_overlay_opacity | divided_by: 200.0 }}) 0%,
          rgba(0, 0, 0, {{ section.settings.mobile_overlay_opacity | divided_by: 200.0 }}) 48%,
          rgba(0, 0, 0, {{ section.settings.mobile_overlay_opacity | divided_by: 100.0 }}) 100%
        );
    }

    #shopify-section-{{ section.id }} .knr-editorial__inner {
      padding:
        max({{ section.settings.mobile_padding_top }}px, env(safe-area-inset-top, 0px) + 32px)
        {{ section.settings.mobile_side_padding }}px
        max({{ section.settings.mobile_padding_bottom }}px, env(safe-area-inset-bottom, 0px) + 56px);
    }

    #shopify-section-{{ section.id }} .knr-editorial__note {
      max-width: 240px;
              margin-left: -80px;
    }

    #shopify-section-{{ section.id }} .knr-editorial__note::after {
      width: 24px;
      margin-top: 14px;
    }

    #shopify-section-{{ section.id }} .knr-editorial__text {
      font-size: {{ section.settings.mobile_body_size }}px;
      line-height: 1.04;
    }
  }
</style>

<section
  class="knr-editorial"
  data-knr-editorial
  data-variants="{{ product.variants | json | escape }}"
>
  <div class="knr-editorial__bg{% if section.settings.bg_image != blank %} knr-editorial__bg--has-desktop{% endif %}{% if section.settings.mobile_bg_image != blank %} knr-editorial__bg--has-mobile{% endif %}" aria-hidden="true">
    {%- if section.settings.bg_image != blank or section.settings.mobile_bg_image != blank -%}
      {%- if section.settings.bg_image != blank -%}
        <img
          class="knr-editorial__bg-img knr-editorial__bg-img--desktop"
          src="{{ section.settings.bg_image | image_url: width: 2200 }}"
          alt=""
          width="2200"
          height="{{ section.settings.desktop_height }}"
          loading="lazy"
        >
      {%- endif -%}
      {%- if section.settings.mobile_bg_image != blank -%}
        <img
          class="knr-editorial__bg-img knr-editorial__bg-img--mobile"
          src="{{ section.settings.mobile_bg_image | image_url: width: 1200 }}"
          alt=""
          width="1200"
          height="{{ section.settings.mobile_height }}"
          loading="lazy"
        >
      {%- endif -%}
    {%- else -%}
      <div class="knr-editorial__fallback"></div>
    {%- endif -%}
  </div>
  <div class="knr-editorial__shade" aria-hidden="true"></div>

  <div class="knr-editorial__inner">
    {%- if section.settings.note_text != blank -%}
      <div class="knr-editorial__note">
        <p>{{ section.settings.note_text }}</p>
      </div>
    {%- endif -%}

    <div class="knr-editorial__content">
      {%- if section.settings.body_text != blank -%}
        <p class="knr-editorial__text">{{ section.settings.body_text }}</p>
      {%- endif -%}
      {%- if section.settings.author != blank -%}
        <p class="knr-editorial__author">{{ section.settings.author }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_product_card and product != blank -%}
    <div class="knr-editorial__product-card">
      <a class="knr-editorial__product-image" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
        {%- if product.featured_media != blank -%}
          <img
            src="{{ product.featured_media | image_url: width: 260 }}"
            alt="{{ product.featured_media.alt | default: product.title | escape }}"
            width="{{ section.settings.card_image_width }}"
            height="110"
            loading="lazy"
          >
        {%- endif -%}
      </a>

      <div class="knr-editorial__product-info">
        <p class="knr-editorial__product-name">{{ product.title }}</p>
        {%- unless product.has_only_default_variant -%}
          <div class="knr-editorial__variant-options">
            {%- assign first_option = product.options_with_values.first -%}
            {%- for option_value in first_option.values limit: 2 -%}
              <button
                class="knr-editorial__variant-option{% if first_option.selected_value == option_value %} is-selected{% endif %}"
                type="button"
                data-variant-option
                data-option-index="0"
                data-option-value="{{ option_value | escape }}"
                aria-pressed="{% if first_option.selected_value == option_value %}true{% else %}false{% endif %}"
              >
                {{ option_value }}
              </button>
            {%- endfor -%}
          </div>
        {%- endunless -%}
        <p class="knr-editorial__product-price" data-product-price>{{ current_variant.price | money }}</p>
      </div>

      <form class="knr-editorial__product-form" id="{{ product_form_id }}" action="{{ routes.cart_add_url }}" method="post">
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>
        <input type="hidden" name="quantity" value="1">
        <button
          type="submit"
          name="add"
          class="knr-editorial__atc"
          data-atc-button
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {%- if current_variant.available -%}
            {{ section.settings.button_label }}
          {%- else -%}
            {{ section.settings.sold_out_label }}
          {%- endif -%}
        </button>
      </form>
    </div>
  {%- endif -%}
</section>

<script>
  (() => {
    const section = document.currentScript.previousElementSibling;
    const form = section?.querySelector('.knr-editorial__product-form');
    const button = section?.querySelector('[data-atc-button]');
    const variantIdInput = section?.querySelector('[data-variant-id-input]');
    const priceEl = section?.querySelector('[data-product-price]');
    const optionButtons = Array.from(section?.querySelectorAll('[data-variant-option]') || []);
    if (!section || !form || !button || !variantIdInput) return;

    const variants = JSON.parse(section.dataset.variants || '[]');
    const moneyFormat = {{ shop.money_format | json }};
    const defaultLabel = {{ section.settings.button_label | json }};
    const soldOutLabel = {{ section.settings.sold_out_label | json }};
    const addingLabel = {{ section.settings.adding_label | json }};
    const addedLabel = {{ section.settings.added_label | json }};

    let selectedOptions = [
      {%- for opt in product.options_with_values -%}
        {{ opt.selected_value | json }}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ];

    const formatMoney = cents => {
      if (typeof Shopify !== 'undefined' && typeof Shopify.formatMoney === 'function') {
        return Shopify.formatMoney(cents, moneyFormat);
      }

      const amount = (Number(cents || 0) / 100).toFixed(2).replace('.', ',');
      return `${amount} €`;
    };

    const getCartUi = () => document.querySelector('cart-notification') || document.querySelector('cart-drawer');

    const openCartUi = cartUi => {
      if (!cartUi) return;
      if (typeof cartUi.open === 'function') {
        cartUi.open();
        return;
      }
      if (typeof cartUi.show === 'function') {
        cartUi.show();
      }
    };

    const syncCartCount = cart => {
      const bubble = document.getElementById('cart-icon-bubble');
      const countBubble = bubble?.querySelector('.cart-count-bubble');

      if (!countBubble) return;

      countBubble.classList.toggle('hidden', cart.item_count === 0);
      countBubble.querySelectorAll('span').forEach(span => {
        if (span.classList.contains('visually-hidden')) {
          span.textContent = `Cart ${cart.item_count} items`;
        } else {
          span.textContent = cart.item_count;
        }
      });
    };

    const findVariant = options => variants.find(variant => variant.options.every((option, index) => option === options[index]));
    const getSelectedVariant = () => findVariant(selectedOptions) || variants.find(variant => variant.available) || variants[0];

    const updateOptionButtons = variant => {
      optionButtons.forEach(optionButton => {
        const optionIndex = Number(optionButton.dataset.optionIndex);
        const optionValue = optionButton.dataset.optionValue;
        const nextSelection = [...selectedOptions];
        nextSelection[optionIndex] = optionValue;

        const matchesVariant = variants.some(item => {
          if (!item.available) return false;
          return item.options.every((value, index) => value === nextSelection[index]);
        });

        const isSelected = variant?.options?.[optionIndex] === optionValue;
        optionButton.classList.toggle('is-selected', isSelected);
        optionButton.setAttribute('aria-pressed', String(isSelected));
        optionButton.disabled = !matchesVariant;
      });
    };

    const updateUi = () => {
      const variant = getSelectedVariant();
      if (!variant) return;

      selectedOptions = [...variant.options];
      variantIdInput.value = variant.id;

      if (priceEl) {
        priceEl.textContent = formatMoney(variant.price);
      }

      button.disabled = !variant.available;
      button.textContent = variant.available ? defaultLabel : soldOutLabel;
      updateOptionButtons(variant);
    };

    optionButtons.forEach(optionButton => {
      optionButton.addEventListener('click', () => {
        if (optionButton.disabled) return;

        const optionIndex = Number(optionButton.dataset.optionIndex);
        const optionValue = optionButton.dataset.optionValue;
        const nextSelection = [...selectedOptions];
        nextSelection[optionIndex] = optionValue;

        let nextVariant = findVariant(nextSelection);
        if (!nextVariant || !nextVariant.available) {
          nextVariant = variants.find(variant => variant.available && variant.options[optionIndex] === optionValue);
        }

        if (!nextVariant) return;
        selectedOptions = [...nextVariant.options];
        updateUi();
      });
    });

    updateUi();

    form.addEventListener('submit', async event => {
      event.preventDefault();
      if (button.disabled) return;

      const label = button.textContent;
      button.disabled = true;
      button.textContent = addingLabel;

      try {
        const cartUi = getCartUi();
        const formData = new FormData();
        formData.append('id', variantIdInput.value);
        formData.append('quantity', String(Number(form.querySelector('[name="quantity"]').value || 1)));

        if (cartUi && typeof cartUi.getSectionsToRender === 'function') {
          formData.append(
            'sections',
            cartUi.getSectionsToRender().map(cartSection => cartSection.id).join(',')
          );
          formData.append('sections_url', window.location.pathname);
          if (typeof cartUi.setActiveElement === 'function') {
            cartUi.setActiveElement(button);
          }
        }

        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            Accept: 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: formData
        });

        if (!response.ok) throw new Error('Cart add failed');

        const addResponse = await response.json();
        if (cartUi && addResponse.sections && typeof cartUi.renderContents === 'function') {
          cartUi.renderContents(addResponse);
        } else {
          openCartUi(cartUi);
        }

        const cart = await (await fetch('/cart.js')).json();
        syncCartCount(cart);
        document.dispatchEvent(new CustomEvent('knr:cart:updated', { detail: cart, bubbles: true }));
        button.textContent = addedLabel;

        setTimeout(() => {
          updateUi();
          if (!button.disabled) {
            button.textContent = label;
          }
        }, 1500);
      } catch (error) {
        updateUi();
        if (!button.disabled) {
          button.textContent = label;
        }
      }
    });
  })();
</script>

{% schema %}
{
  "name": "KNR Editorial",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "image_picker", "id": "mobile_bg_image", "label": "Mobile background image" },
    { "type": "text", "id": "note_text", "label": "Left note", "default": "Notre engagement pour une beauté régénérée" },
    { "type": "textarea", "id": "body_text", "label": "Main text", "default": "Fusionnant l'huile de rosier muscat, le rétinol végétal et l'extrait de cactus, notre sérum pénètre en profondeur pour stimuler le renouvellement cellulaire, atténuer les rides et redonner à la peau son éclat et sa fermeté naturels." },
    { "type": "text", "id": "author", "label": "Small author text", "default": "Sophie M." },
    { "type": "checkbox", "id": "show_product_card", "label": "Show floating product card", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Ajouter au panier" },
    { "type": "text", "id": "sold_out_label", "label": "Sold out label", "default": "Indisponible" },
    { "type": "text", "id": "adding_label", "label": "Adding label", "default": "Ajout..." },
    { "type": "text", "id": "added_label", "label": "Added label", "default": "Ajouté" },
    { "type": "color", "id": "fallback_bg", "label": "Fallback background", "default": "#777162" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "card_bg", "label": "Product card background", "default": "#ffffff" },
    { "type": "color", "id": "card_text_color", "label": "Product card text", "default": "#111111" },
    { "type": "color", "id": "card_border_color", "label": "Product card border", "default": "#ece7dd" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#000000" },
