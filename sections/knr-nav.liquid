<style>
  .knr-nav {
    position: sticky;
    top: 36px;
    z-index: 50;
    background: var(--knr-sand);
    border-bottom: 1px solid var(--knr-border);
    font-family: var(--knr-font);
    width: 100%;
    max-width: {{ section.settings.section_max_width }}px;
    margin: 0 auto;
  }

  .knr-nav__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: {{ section.settings.section_max_width }}px;
    margin: 0 auto;
    padding: 0 28px;
    height: 62px;
  }

  .knr-nav__links {
    display: flex;
    gap: 32px;
  }

  .knr-nav__link {
    font-size: var(--knr-text-12);
    letter-spacing: .06em;
    color: var(--knr-ink);
    transition: opacity .15s;
  }

  .knr-nav__link:hover { opacity: .5; }

  .knr-nav__logo {
    font-size: var(--knr-text-13);
    font-weight: 300;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--knr-ink);
    white-space: nowrap;
    text-align: center;
  }

  .knr-nav__logo img {
    height: 26px;
    width: auto;
    margin: 0 auto;
  }

  .knr-nav__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
  }

  .knr-nav__action {
    font-size: var(--knr-text-12);
    letter-spacing: .06em;
    color: var(--knr-ink);
    transition: opacity .15s;
  }

  .knr-nav__action:hover { opacity: .5; }

  .knr-nav__cart {
    position: relative;
    display: flex;
    align-items: center;
  }

  .knr-nav__cart svg {
    width: 19px;
    height: 19px;
    stroke: var(--knr-ink);
    stroke-width: 1.4;
    fill: none;
  }

  .knr-nav__cart-count {
    position: absolute;
    top: -7px;
    right: -9px;
    min-width: 15px;
    height: 15px;
    background: var(--knr-ink);
    color: var(--knr-cream);
    font-size: 9px;
    font-weight: 500;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    padding: 0 2px;
    transition: opacity .15s;
  }

  .knr-nav__cart-count[data-empty="true"] { display: none; }

  /* hamburger */
  .knr-nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
  }

  .knr-nav__burger span {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--knr-ink);
    transition: transform .25s, opacity .25s;
  }

  /* mobile drawer */
  .knr-nav__drawer {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--knr-sand);
    z-index: 200;
    padding: 24px 24px 40px;
    flex-direction: column;
  }

  .knr-nav__drawer.is-open { display: flex; }

  .knr-nav__drawer-close {
    align-self: flex-end;
    background: none;
    border: none;
    font-size: 22px;
    color: var(--knr-ink);
    cursor: pointer;
    margin-bottom: 32px;
    line-height: 1;
  }

  .knr-nav__drawer-link {
    font-size: 22px;
    font-weight: 300;
    letter-spacing: .05em;
    color: var(--knr-ink);
    padding: 14px 0;
    border-bottom: 1px solid var(--knr-border);
    font-family: var(--knr-font);
  }

  @media (max-width: 860px) {
    .knr-nav__links,
    .knr-nav__action:not(.knr-nav__cart) {
      display: none;
    }

    .knr-nav__inner {
      grid-template-columns: 40px 1fr 40px;
      padding: 0 16px;
    }

    .knr-nav__burger { display: flex; }
  }
</style>

<header class="knr-nav">
  <div class="knr-nav__inner">

    <button class="knr-nav__burger" id="knrBurger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="knr-nav__links" aria-label="Navigation principale">
      {%- for link in linklists[section.settings.menu].links limit: 4 -%}
        <a href="{{ link.url }}" class="knr-nav__link">{{ link.title }}</a>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}" class="knr-nav__link">Boutique</a>
        <a href="/pages/ingredients" class="knr-nav__link">Ingrédients</a>
        <a href="/pages/rituels" class="knr-nav__link">Rituels</a>
      {%- endfor -%}
    </nav>

    <a href="{{ routes.root_url }}" class="knr-nav__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" width="150" height="26" loading="eager">
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>

    <div class="knr-nav__actions">
      {%- for link in linklists[section.settings.menu].links offset: 4 limit: 1 -%}
        <a href="{{ link.url }}" class="knr-nav__action">{{ link.title }}</a>
      {%- else -%}
        <a href="/pages/notre-histoire" class="knr-nav__action">Notre histoire</a>
      {%- endfor -%}

      <a href="{{ routes.cart_url }}" class="knr-nav__action knr-nav__cart" aria-label="Panier ({{ cart.item_count }})">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/>
        </svg>
        <span
          class="knr-nav__cart-count"
          id="knrCartCount"
          data-empty="{% if cart.item_count == 0 %}true{% else %}false{% endif %}"
          aria-hidden="true"
        >{{ cart.item_count }}</span>
      </a>
    </div>

  </div>
</header>

<nav class="knr-nav__drawer" id="knrDrawer" aria-label="Mobile navigation" aria-hidden="true">
  <button class="knr-nav__drawer-close" id="knrDrawerClose" aria-label="Fermer">&#x2715;</button>
  {%- for link in linklists[section.settings.menu].links -%}
    <a href="{{ link.url }}" class="knr-nav__drawer-link">{{ link.title }}</a>
  {%- else -%}
    <a href="{{ routes.all_products_collection_url }}" class="knr-nav__drawer-link">Boutique</a>
    <a href="/pages/ingredients" class="knr-nav__drawer-link">Ingrédients</a>
    <a href="/pages/rituels" class="knr-nav__drawer-link">Rituels</a>
    <a href="/pages/notre-histoire" class="knr-nav__drawer-link">Notre histoire</a>
  {%- endfor -%}
</nav>

<script>
  (() => {
    // dynamic sticky top: sit immediately below the announcement bar
    const nav = document.querySelector('.knr-nav');
    const setNavTop = () => {
      const announce = document.querySelector('.knr-announce');
      if (nav) nav.style.top = announce ? announce.offsetHeight + 'px' : '0px';
    };
    setNavTop();
    window.addEventListener('resize', setNavTop);

    // cart badge: listen for AJAX add-to-cart updates
    const badge = document.getElementById('knrCartCount');
    document.addEventListener('knr:cart:updated', e => {
      if (!badge) return;
      const count = e.detail?.item_count ?? 0;
      badge.textContent = count;
      badge.dataset.empty = count === 0 ? 'true' : 'false';
    });

    // mobile drawer
    const burger = document.getElementById('knrBurger');
    const drawer = document.getElementById('knrDrawer');
    const drawerClose = document.getElementById('knrDrawerClose');

    const openDrawer = () => {
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };

    const closeDrawer = () => {
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    burger.addEventListener('click', openDrawer);
    drawerClose.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrawer(); });
  })();
</script>

{% schema %}
{
  "name": "KNR Navigation",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Section max width",
      "min": 960,
      "max": 1680,
      "step": 20,
      "default": 1440
    }
  ],
  "presets": [{ "name": "KNR Navigation" }]
}
{% endschema %}
