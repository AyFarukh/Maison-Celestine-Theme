<style>
  #shopify-section-{{ section.id }} .knr-news-showcase {
    --knr-news-bg: {{ section.settings.bg_color }};
    --knr-news-ink: {{ section.settings.text_color }};
    --knr-news-muted: {{ section.settings.muted_color }};
    --knr-news-rule: {{ section.settings.rule_color }};
    background: var(--knr-news-bg);
    color: var(--knr-news-ink);
    font-family: var(--knr-font);
    padding: {{ section.settings.padding_top }}px {{ section.settings.side_padding }}px {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    width: 100%;
    {% comment %} max-width: {{ section.settings.section_max_width }}px; {% endcomment %}
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .knr-news-showcase__inner {
    {% comment %} max-width: {{ section.settings.section_max_width }}px; {% endcomment %}
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .knr-news-showcase__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: {{ section.settings.header_gap }}px;
  }

  #shopify-section-{{ section.id }} .knr-news-showcase__title {
    color: var(--knr-news-ink);
    font-size: {{ section.settings.title_size }}px;
        font-weight: 400;
    line-height: 1.08;
    letter-spacing: 0;
    margin: 0;
    font-family: 'Inter';
  }

  #shopify-section-{{ section.id }} .knr-news-showcase__all {
    color: var(--knr-news-ink);
    display: inline-flex;
    width: max-content;
    border-bottom: 1px solid currentColor;
    font-size: {{ section.settings.link_size }}px;
    line-height: 1.4;
    text-decoration: none;
    transition: opacity .18s ease;
  }

  #shopify-section-{{ section.id }} .knr-news-showcase__all:hover {
    opacity: .58;
  }

  #shopify-section-{{ section.id }} .knr-news-showcase__viewport {
    overflow: visible;
  }

  #shopify-section-{{ section.id }} .knr-news-showcase__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.column_gap }}px;
  }

  #shopify-section-{{ section.id }} .knr-news-item {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .knr-news-item__media {
    display: block;
    aspect-ratio: {{ section.settings.image_ratio }};
    background: var(--knr-news-rule);
    overflow: hidden;
    margin-bottom: {{ section.settings.image_text_gap }}px;
  }

  #shopify-section-{{ section.id }} .knr-news-item__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform .55s ease;
  }

  #shopify-section-{{ section.id }} .knr-news-item:hover .knr-news-item__media img {
    transform: scale(1.025);
  }

  #shopify-section-{{ section.id }} .knr-news-item__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg, rgba(255,255,255,.42), rgba(0,0,0,.04)),
      var(--knr-news-rule);
  }

  #shopify-section-{{ section.id }} .knr-news-item__kicker {
    color: var(--knr-news-ink);
    font-size: {{ section.settings.kicker_size }}px;
    line-height: 1.45;
       margin: 0 0 16px;
    text-decoration: underline;
  }

  #shopify-section-{{ section.id }} .knr-news-item__rule {
    width: 18px;
    height: 1px;
    background: var(--knr-news-rule);
    margin: {{ section.settings.rule_gap }}px 0 {{ section.settings.title_gap }}px;
  }

  #shopify-section-{{ section.id }} .knr-news-item__title {
    color: var(--knr-news-ink);
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: 300;
    line-height: 1.22;
    letter-spacing: 0;
    margin: 0 0 16px;
  }

  #shopify-section-{{ section.id }} .knr-news-item__title a {
    color: inherit;
    text-decoration: none;
    transition: opacity .18s ease;
  }

  #shopify-section-{{ section.id }} .knr-news-item__title a:hover {
    opacity: .58;
  }

  #shopify-section-{{ section.id }} .knr-news-item__excerpt {
    color: var(--knr-news-ink);
    font-size: {{ section.settings.excerpt_size }}px;
    line-height: 1.48;
    margin: 0;
        font-weight: 400;
  }

  #shopify-section-{{ section.id }} .knr-news-showcase__mobile-footer {
    display: none;
  }

  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .knr-news-showcase {
      padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_side_padding }}px {{ section.settings.mobile_padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .knr-news-showcase__header {
      display: block;
      margin-bottom: {{ section.settings.mobile_header_gap }}px;
    }

    #shopify-section-{{ section.id }} .knr-news-showcase__title {
      font-size: {{ section.settings.mobile_title_size }}px;
    }

    #shopify-section-{{ section.id }} .knr-news-showcase__header .knr-news-showcase__all {
      display: none;
    }

    #shopify-section-{{ section.id }} .knr-news-showcase__viewport {
      overflow-x: auto;
      overflow-y: hidden;
      margin-left: calc({{ section.settings.mobile_side_padding }}px * -1);
      margin-right: calc({{ section.settings.mobile_side_padding }}px * -1);
      padding-left: {{ section.settings.mobile_side_padding }}px;
      padding-right: {{ section.settings.mobile_side_padding }}px;
      scroll-snap-type: x mandatory;
      scroll-padding-left: {{ section.settings.mobile_side_padding }}px;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    #shopify-section-{{ section.id }} .knr-news-showcase__viewport::-webkit-scrollbar {
      display: none;
    }

    #shopify-section-{{ section.id }} .knr-news-showcase__grid {
      display: flex;
      gap: {{ section.settings.mobile_column_gap }}px;
    }

    #shopify-section-{{ section.id }} .knr-news-item {
      flex: 0 0 {{ section.settings.mobile_card_width }}%;
      scroll-snap-align: start;
    }

    #shopify-section-{{ section.id }} .knr-news-item__media {
      aspect-ratio: {{ section.settings.mobile_image_ratio }};
      margin-bottom: {{ section.settings.mobile_image_text_gap }}px;
    }

    #shopify-section-{{ section.id }} .knr-news-item__kicker {
      font-size: {{ section.settings.mobile_kicker_size }}px;
    }

    #shopify-section-{{ section.id }} .knr-news-item__title {
      font-size: {{ section.settings.mobile_card_title_size }}px;
      line-height: 1.23;
    }

    #shopify-section-{{ section.id }} .knr-news-item__excerpt {
      font-size: {{ section.settings.mobile_excerpt_size }}px;
      line-height: 1.55;
    }

    #shopify-section-{{ section.id }} .knr-news-showcase__mobile-footer {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 36px;
      margin-top: {{ section.settings.mobile_footer_gap }}px;
    }

    #shopify-section-{{ section.id }} .knr-news-showcase__scrollbar {
      width: {{ section.settings.mobile_indicator_width }}px;
      height: 1px;
      background: var(--knr-news-rule);
      position: relative;
    }

    #shopify-section-{{ section.id }} .knr-news-showcase__scrollbar-thumb {
      position: absolute;
      top: 0;
      left: 0;
      width: 0%;
      height: 1px;
      background: var(--knr-news-ink);
      transition: width 0.2s ease, left 0.2s ease;
    }
  }
</style>

{%- liquid
  assign article_blocks = section.blocks | where: 'type', 'article'
  assign selected_blog = section.settings.blog
  assign all_url = section.settings.all_link
  if all_url == blank and selected_blog != blank
    assign all_url = blogs[selected_blog].url
  endif
-%}

<section class="knr-news-showcase">
  <div class="knr-news-showcase__inner ">
    <div class="knr-news-showcase__header">
      <h2 class="knr-news-showcase__title">{{ section.settings.title }}</h2>
      {%- if section.settings.show_all_link and all_url != blank -%}
        <a class="knr-news-showcase__all" href="{{ all_url }}">{{ section.settings.all_label }}</a>
      {%- endif -%}
    </div>

    <div class="knr-news-showcase__viewport">
      <div class="knr-news-showcase__grid">
        {%- if selected_blog != blank and blogs[selected_blog].articles.size > 0 -%}
          {%- for article in blogs[selected_blog].articles limit: section.settings.count -%}
            <article class="knr-news-item">
              <a class="knr-news-item__media" href="{{ article.url }}" tabindex="-1" aria-hidden="true">
                {%- if article.image != blank -%}
                  <img
                    src="{{ article.image | image_url: width: 900 }}"
                    alt="{{ article.image.alt | default: article.title | escape }}"
                    width="720"
                    height="520"
                    loading="lazy"
                  >
                {%- else -%}
                  <span class="knr-news-item__placeholder" aria-hidden="true"></span>
                {%- endif -%}
              </a>
              <p class="knr-news-item__kicker">{{ article.tags.first | default: section.settings.default_kicker }}</p>
              <div class="knr-news-item__rule" aria-hidden="true"></div>
              <h3 class="knr-news-item__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>
              {%- assign article_excerpt = article.excerpt | default: article.content | strip_html -%}
              {%- if article_excerpt != blank -%}
                <p class="knr-news-item__excerpt">{{ article_excerpt | truncate: section.settings.excerpt_length }}</p>
              {%- endif -%}
            </article>
          {%- endfor -%}
        {%- else -%}
          {%- for block in article_blocks limit: section.settings.count -%}
            <article class="knr-news-item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a class="knr-news-item__media" href="{{ block.settings.link }}" tabindex="-1" aria-hidden="true">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 900 }}"
                      alt="{{ block.settings.title | escape }}"
                      width="720"
                      height="520"
                      loading="lazy"
                    >
                  {%- else -%}
                    <span class="knr-news-item__placeholder" aria-hidden="true"></span>
                  {%- endif -%}
                </a>
              {%- else -%}
                <div class="knr-news-item__media">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 900 }}"
                      alt="{{ block.settings.title | escape }}"
                      width="720"
                      height="520"
                      loading="lazy"
                    >
                  {%- else -%}
                    <span class="knr-news-item__placeholder" aria-hidden="true"></span>
                  {%- endif -%}
                </div>
              {%- endif -%}
              <p class="knr-news-item__kicker">{{ block.settings.kicker }}</p>
              <div class="knr-news-item__rule" aria-hidden="true"></div>
              <h3 class="knr-news-item__title">
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}">{{ block.settings.title }}</a>
                {%- else -%}
                  {{ block.settings.title }}
                {%- endif -%}
              </h3>
              {%- if block.settings.excerpt != blank -%}
                <p class="knr-news-item__excerpt">{{ block.settings.excerpt }}</p>
              {%- endif -%}
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <div class="knr-news-showcase__mobile-footer">
      <div class="knr-news-showcase__scrollbar" aria-hidden="true">
        <div class="knr-news-showcase__scrollbar-thumb"></div>
      </div>
      {%- if section.settings.show_all_link and all_url != blank -%}
        <a class="knr-news-showcase__all" href="{{ all_url }}">{{ section.settings.all_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function () {
  var section = document.querySelector('#shopify-section-{{ section.id }}');
  if (!section) return;
  var viewport = section.querySelector('.knr-news-showcase__viewport');
  var thumb    = section.querySelector('.knr-news-showcase__scrollbar-thumb');
  if (!viewport || !thumb) return;

  function updateThumb() {
    var scrollable = viewport.scrollWidth - viewport.clientWidth;
    if (scrollable <= 0) { thumb.style.width = '100%'; thumb.style.left = '0%'; return; }
    var progress  = viewport.scrollLeft / scrollable;          /* 0 → 1 */
    var items     = viewport.querySelectorAll('.knr-news-item').length || 1;
    var thumbPct  = Math.round(100 / items);
    var leftPct   = Math.round(progress * (100 - thumbPct));
    thumb.style.width = thumbPct + '%';
    thumb.style.left  = leftPct  + '%';
  }

  viewport.addEventListener('scroll', updateThumb, { passive: true });
  /* init after images settle */
  setTimeout(updateThumb, 100);
  window.addEventListener('resize', updateThumb, { passive: true });
})();
</script>

{% schema %}
